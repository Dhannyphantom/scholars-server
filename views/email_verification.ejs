<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>Verify Your Email – <%= appName %></title>
    <style>
      /* ── Reset ── */
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background-color: #f0f4f8;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        color: #1a1a2e;
        -webkit-font-smoothing: antialiased;
      }

      /* ── Outer wrapper ── */
      .email-wrapper {
        width: 100%;
        padding: 40px 16px;
        background-color: #f0f4f8;
      }

      /* ── Card ── */
      .email-card {
        max-width: 560px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
      }

      /* ── Header ── */
      .email-header {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        padding: 36px 40px 32px;
        text-align: center;
      }

      .email-header .logo-text {
        font-size: 26px;
        font-weight: 800;
        color: #ffffff;
        letter-spacing: -0.5px;
      }

      .email-header .logo-text span {
        color: #a5f3fc;
      }

      .email-header .tagline {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.75);
        margin-top: 4px;
        letter-spacing: 0.4px;
      }

      /* ── Body ── */
      .email-body {
        padding: 40px 40px 32px;
      }

      .greeting {
        font-size: 22px;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 12px;
      }

      .intro-text {
        font-size: 15px;
        color: #4b5563;
        line-height: 1.65;
        margin-bottom: 32px;
      }

      /* ── OTP Block ── */
      .otp-block {
        background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%);
        border: 1.5px solid #c4b5fd;
        border-radius: 12px;
        padding: 28px 24px;
        text-align: center;
        margin-bottom: 28px;
      }

      .otp-label {
        font-size: 12px;
        font-weight: 600;
        color: #7c3aed;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        margin-bottom: 14px;
      }

      .otp-code {
        font-size: 48px;
        font-weight: 800;
        color: #4f46e5;
        letter-spacing: 10px;
        line-height: 1;
        font-variant-numeric: tabular-nums;
      }

      .otp-expiry {
        font-size: 13px;
        color: #6b7280;
        margin-top: 14px;
      }

      .otp-expiry strong {
        color: #4f46e5;
      }

      /* ── Info box ── */
      .info-box {
        background-color: #f8fafc;
        border-left: 4px solid #4f46e5;
        border-radius: 0 8px 8px 0;
        padding: 16px 18px;
        margin-bottom: 28px;
      }

      .info-box p {
        font-size: 13.5px;
        color: #374151;
        line-height: 1.6;
      }

      .info-box p + p {
        margin-top: 8px;
      }

      /* ── Warning box ── */
      .warning-box {
        background-color: #fffbeb;
        border: 1px solid #fde68a;
        border-radius: 8px;
        padding: 14px 18px;
        margin-bottom: 32px;
        display: flex;
        align-items: flex-start;
        gap: 10px;
      }

      .warning-icon {
        font-size: 18px;
        line-height: 1.4;
        flex-shrink: 0;
      }

      .warning-box p {
        font-size: 13px;
        color: #92400e;
        line-height: 1.55;
      }

      /* ── Divider ── */
      .divider {
        height: 1px;
        background-color: #e5e7eb;
        margin: 0 0 28px;
      }

      /* ── Steps ── */
      .steps-title {
        font-size: 14px;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 14px;
        text-transform: uppercase;
        letter-spacing: 0.6px;
      }

      .steps-list {
        list-style: none;
        padding: 0;
        margin-bottom: 32px;
      }

      .steps-list li {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 12px;
        font-size: 14px;
        color: #4b5563;
        line-height: 1.55;
      }

      .step-num {
        width: 24px;
        height: 24px;
        background-color: #4f46e5;
        color: #ffffff;
        border-radius: 50%;
        font-size: 12px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 1px;
      }

      /* ── Footer ── */
      .email-footer {
        background-color: #f9fafb;
        border-top: 1px solid #e5e7eb;
        padding: 24px 40px;
        text-align: center;
      }

      .footer-text {
        font-size: 12.5px;
        color: #9ca3af;
        line-height: 1.7;
      }

      .footer-text a {
        color: #4f46e5;
        text-decoration: none;
      }

      .footer-text a:hover {
        text-decoration: underline;
      }

      .footer-brand {
        font-size: 13px;
        font-weight: 700;
        color: #6b7280;
        margin-top: 10px;
      }

      /* ── Responsive ── */
      @media only screen and (max-width: 480px) {
        .email-body {
          padding: 28px 24px 24px;
        }

        .email-header {
          padding: 28px 24px;
        }

        .email-footer {
          padding: 20px 24px;
        }

        .otp-code {
          font-size: 38px;
          letter-spacing: 8px;
        }

        .greeting {
          font-size: 19px;
        }
      }
    </style>
  </head>

  <body>
    <div class="email-wrapper">
      <div class="email-card">

        <!-- ══ HEADER ══ -->
        <div class="email-header">
          <div class="logo-text">
            Guru <span>EduTech</span>
          </div>
          <div class="tagline">Empowering students. Inspiring excellence.</div>
        </div>

        <!-- ══ BODY ══ -->
        <div class="email-body">

          <h1 class="greeting">Hi <%= userName %> 👋</h1>

          <p class="intro-text">
            You requested to verify the email address associated with your
            <strong><%= appName %></strong> account. Use the one-time code
            below to complete the verification. This keeps your account secure
            and ensures we can reach you when it matters.
          </p>

          <!-- OTP Block -->
          <div class="otp-block">
            <div class="otp-label">Your Verification Code</div>
            <div class="otp-code"><%= otp %></div>
            <div class="otp-expiry">
              This code expires in <strong><%= expiryMinutes %> minutes</strong>
            </div>
          </div>

          <!-- Info box -->
          <div class="info-box">
            <p>
              Enter this code in the app where you were asked to verify your
              email. Do <strong>not</strong> share this code with anyone —
              <%= appName %> staff will never ask for it.
            </p>
            <p>
              If you did not request this, you can safely ignore this email.
              Your account will not be affected.
            </p>
          </div>

          <!-- Warning -->
          <div class="warning-box">
            <span class="warning-icon">⚠️</span>
            <p>
              For your security, this code is valid for a
              <strong>single use only</strong> and will expire after
              <strong><%= expiryMinutes %> minutes</strong>. After
              <strong>5 failed attempts</strong>, the code will be invalidated
              and you will need to request a new one.
            </p>
          </div>

          <div class="divider"></div>

          <!-- Steps -->
          <div class="steps-title">How to verify</div>
          <ul class="steps-list">
            <li>
              <span class="step-num">1</span>
              <span>Go back to the <strong><%= appName %></strong> app on your device.</span>
            </li>
            <li>
              <span class="step-num">2</span>
              <span>Find the <strong>Enter OTP</strong> field that appeared below your email input.</span>
            </li>
            <li>
              <span class="step-num">3</span>
              <span>Type in the 6-digit code shown above and tap <strong>Verify</strong>.</span>
            </li>
            <li>
              <span class="step-num">4</span>
              <span>Once verified, tap <strong>Update Profile</strong> to save your changes.</span>
            </li>
          </ul>

        </div>

        <!-- ══ FOOTER ══ -->
        <div class="email-footer">
          <p class="footer-text">
            Need help? Reach our support team at
            <a href="mailto:<%= supportEmail %>"><%= supportEmail %></a>
          </p>
          <p class="footer-text" style="margin-top: 6px;">
            This email was sent to you because a profile update was initiated
            on your <strong><%= appName %></strong> account. If this wasn't
            you, please contact support immediately.
          </p>
          <p class="footer-brand">
            &copy; <%= year %> <%= appName %>. All rights reserved.
          </p>
        </div>

      </div>
    </div>
  </body>
</html>
